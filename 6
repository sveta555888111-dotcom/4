Удаление элемента с конца связного списка.
Дополнительно: реализуйте все оставшиеся операции из задачи № 1 для двунаправленного связного списка.

class DNode:
    def __init__(self, v):
        self.val = v
        self.prev = None
        self.next = None

class DLinkedList:
    def __init__(self):
        self.head = None
        self.tail = None

    def show(self):
        cur = self.head
        while cur:
            print(cur.val, end=' <-> ' if cur.next else '')
            cur = cur.next
        print()

    def append(self, v):
        new = DNode(v)
        if not self.head:
            self.head = self.tail = new
        else:
            self.tail.next = new
            new.prev = self.tail
            self.tail = new

    def prepend(self, v):
        new = DNode(v)
        if not self.head:
            self.head = self.tail = new
        else:
            new.next = self.head
            self.head.prev = new
            self.head = new

    def pop_back(self):
        if not self.tail:
            return None
        val = self.tail.val
        if self.head == self.tail:
            self.head = self.tail = None
        else:
            self.tail = self.tail.prev
            self.tail.next = None
        return val

    def pop_front(self):
        if not self.head:
            return None
        val = self.head.val
        if self.head == self.tail:
            self.head = self.tail = None
        else:
            self.head = self.head.next
            self.head.prev = None
        return val

    def search(self, v):
        cur = self.head
        while cur:
            if cur.val == v:
                return True
            cur = cur.next
        return False

    def insert_after(self, target, v):
        cur = self.head
        while cur:
            if cur.val == target:
                new = DNode(v)
                new.prev = cur
                new.next = cur.next
                if cur.next:
                    cur.next.prev = new
                else:
                    self.tail = new
                cur.next = new
                return
            cur = cur.next
        raise ValueError("Элемент не найден")

    def delete(self, v):
        cur = self.head
        while cur:
            if cur.val == v:
                if cur.prev:
                    cur.prev.next = cur.next
                else:
                    self.head = cur.next
                if cur.next:
                    cur.next.prev = cur.prev
                else:
                    self.tail = cur.prev
                return
            cur = cur.next
        raise ValueError("Элемент не найден")

