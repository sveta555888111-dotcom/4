class CNode:
    def __init__(self, v):
        self.val = v
        self.next = None

class CircularLinkedList:
    def __init__(self):
        self.head = None
        self.tail = None

    def show(self):
        if not self.head:
            print("пустой")
            return
        cur = self.head
        while True:
            print(cur.val, end=' -> ')
            cur = cur.next
            if cur == self.head:
                break
        print("(цикл)")

    def append(self, v):
        new = CNode(v)
        if not self.head:
            self.head = self.tail = new
            new.next = new
        else:
            new.next = self.head
            self.tail.next = new
            self.tail = new

    def prepend(self, v):
        new = CNode(v)
        if not self.head:
            self.head = self.tail = new
            new.next = new
        else:
            new.next = self.head
            self.tail.next = new
            self.head = new

    def pop_back(self):
        if not self.head:
            return None
        if self.head == self.tail:
            val = self.head.val
            self.head = self.tail = None
            return val
        cur = self.head
        while cur.next != self.tail:
            cur = cur.next
        val = self.tail.val
        cur.next = self.head
        self.tail = cur
        return val

    def pop_front(self):
        if not self.head:
            return None
        val = self.head.val
        if self.head == self.tail:
            self.head = self.tail = None
        else:
            self.head = self.head.next
            self.tail.next = self.head
        return val

    def search(self, v):
        if not self.head:
            return False
        cur = self.head
        while True:
            if cur.val == v:
                return True
            cur = cur.next
            if cur == self.head:
                break
        return False

    def insert_after(self, target, v):
        if not self.head:
            raise ValueError("Список пуст")
        cur = self.head
        while True:
            if cur.val == target:
                new = CNode(v)
                new.next = cur.next
                cur.next = new
                if cur == self.tail:
                    self.tail = new
                return
            cur = cur.next
            if cur == self.head:
                break
        raise ValueError("Элемент не найден")

    def delete(self, v):
        if not self.head:
            raise ValueError("Список пуст")
        if self.head.val == v:
            self.pop_front()
            return
        cur = self.head
        while cur.next != self.head:
            if cur.next.val == v:
                if cur.next == self.tail:
                    self.tail = cur
                cur.next = cur.next.next
                return
            cur = cur.next
        raise ValueError("Элемент не найден")

