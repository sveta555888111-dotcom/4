def task4a(numbers):
    q = Queue()
    for x in numbers:
        q.enqueue(x)
    extracted = []
    while not q.is_empty():
        extracted.append(q.dequeue())
    print("Извлечённые элементы:", extracted)
    print("Количество извлечённых элементов:", len(extracted))

