Задача № 1
Реализуйте однонаправленный связный список путем создания класса в Python. При этом в виде методов класса для однонаправленного связного списка реализовать операции:
Чтение всех элементов.
Вставка элемента в конец связного списка.
Вставка элемента в начало связного списка.
Удаление элемента с конца связного списка.
Удаление элемента с начала связного списка.
Поиск элемента в связном списке.
Вставка элемента после указанного элемента.
Удаление указанного элемента.

class Node:
    def __init__(self, v):
        self.val = v
        self.next = None

class SLinkedList:
    def __init__(self):
        self.head = None

    def show(self):
        cur = self.head
        while cur:
            print(cur.val, end=' -> ' if cur.next else '')
            cur = cur.next
        print()

    def append(self, v):
        new = Node(v)
        if not self.head:
            self.head = new
            return
        cur = self.head
        while cur.next:
            cur = cur.next
        cur.next = new

    def prepend(self, v):
        new = Node(v)
        new.next = self.head
        self.head = new

    def pop_back(self):
        if not self.head:
            return None
        if not self.head.next:
            val = self.head.val
            self.head = None
            return val
        cur = self.head
        while cur.next.next:
            cur = cur.next
        val = cur.next.val
        cur.next = None
        return val

    def pop_front(self):
        if not self.head:
            return None
        val = self.head.val
        self.head = self.head.next
        return val

    def search(self, v):
        cur = self.head
        while cur:
            if cur.val == v:
                return True
            cur = cur.next
        return False

    def insert_after(self, target, v):
        cur = self.head
        while cur:
            if cur.val == target:
                new = Node(v)
                new.next = cur.next
                cur.next = new
                return
            cur = cur.next
        raise ValueError("Элемент не найден")

    def delete(self, v):
        if not self.head:
            return
        if self.head.val == v:
            self.head = self.head.next
            return
        cur = self.head
        while cur.next:
            if cur.next.val == v:
                cur.next = cur.next.next
                return
            cur = cur.next
        raise ValueError("Элемент не найден")

