# queue.LifoQueue
from queue import LifoQueue
N = int(input())
stack = LifoQueue()
for _ in range(N):
    x = int(input())
    stack.put(x)

count = 0
while not stack.empty():
    print(stack.get())
    count += 1
print(count)



