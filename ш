from collections import deque
from queue import Queue

# с deque
def merge_sorted_queues(q1, q2):
    result = deque()
    while q1 and q2:
        if q1[0] < q2[0]:
            result.append(q1.popleft())
        else:
            result.append(q2.popleft())
    result.extend(q1)
    result.extend(q2)
    return result

q1 = deque(sorted([1,4,7]))
q2 = deque(sorted([2,3,6]))
merged = merge_sorted_queues(q1, q2)

# с queue.Queue
def merge_queues(q1, q2):
    result = Queue()
    elem1 = q1.get() if not q1.empty() else None
    elem2 = q2.get() if not q2.empty() else None

    while elem1 is not None and elem2 is not None:
        if elem1 < elem2:
            result.put(elem1)
            elem1 = q1.get() if not q1.empty() else None
        else:
            result.put(elem2)
            elem2 = q2.get() if not q2.empty() else None

    while elem1 is not None:
        result.put(elem1)
        elem1 = q1.get() if not q1.empty() else None

    while elem2 is not None:
        result.put(elem2)
        elem2 = q2.get() if not q2.empty() else None
    return result

