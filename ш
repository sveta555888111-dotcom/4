Задача № 1
Дано число N (> 0) и набор из N чисел. Создать стек, содержащий исходные числа (последнее число будет вершиной стека). Извлечь из стека все элементы и вывести их значения. Вывести также количество извлеченных элементов N.
Стек необходимо реализовать, используя:
a.	Встроенный список (list)
b.	Класс collections.deque
c.	Класс queue.LifoQueue

Встроенный список:
N = int(input())
stack = []
for _ in range(N):
    x = int(input())
    stack.append(x)

count = 0
while stack:
    print(stack.pop())
    count += 1
print(count)

# collections.deque
from collections import deque
N = int(input())
stack = deque()
for _ in range(N):
    x = int(input())
    stack.append(x)

count = 0
while stack:
    print(stack.pop())
    count += 1
print(count)

# queue.LifoQueue
from queue import LifoQueue
N = int(input())
stack = LifoQueue()
for _ in range(N):
    x = int(input())
    stack.put(x)

count = 0
while not stack.empty():
    print(stack.get())
    count += 1
print(count)



